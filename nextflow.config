manifest {
  name            = 'read-clean-asm_wf'
  author          = 'Karthik Krishnan'
  homePage        = 'https://github.com/karthik-krishnan-28/read-clean-asm_wf'
  description     = 'Simple Nextflow workflow: fastp -> (skesa + seqkit)'
  nextflowVersion = '>=24.10.0'
}

params {
  outdir = 'results'
  input  = 'assets/test_samplesheet.csv'
}

process
{
	withName: FASTP{
		container = 'quay.io/biocontainers/fastp:1.3.2--h43da1c4_0'
			}
	withName: SKESA{
		container = 'quay.io/biocontainers/skesa:2.5.1--hdcf5f25_0'
			}
  withName: SEQKIT_STATS{
    container = 'quay.io/biocontainers/seqkit:2.13.0--he881be0_0'
  }  
}

profiles {
  conda {
    conda.enabled = true
    process.executor = 'local'
  }
  docker {
    docker.enabled = true
  }
}

timeline {
  enabled = true
  file = "${params.outdir}/pipeline_timeline.html"
}

report {
  enabled = true
  file = "${params.outdir}/pipeline_report.html"
}

trace {
  enabled = true
  file = "${params.outdir}/pipeline_trace.txt"
}

dag {
  enabled = true
  file = "${params.outdir}/pipeline_dag.html"
}